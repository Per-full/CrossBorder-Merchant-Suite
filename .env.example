# 应用配置
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# TikTok Shop API
TIKTOK_SHOP_API_KEY=
TIKTOK_SHOP_API_SECRET=
TIKTOK_SHOP_BASE_URL=https://api.tiktokshop.com

# 咸鱼 (Xianyu) API
XIANYU_API_KEY=
XIANYU_API_SECRET=
XIANYU_BASE_URL=https://openapi.xianyu.com

# 1688 API
ALIBABA_1688_API_KEY=
ALIBABA_1688_API_SECRET=
ALIBABA_1688_BASE_URL=https://api.1688.com

# 数据库
DATABASE_URL=sqlite://./database.db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crossborder_db
DB_USER=postgres
DB_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 日志
LOG_LEVEL=info
LOG_FILE=logs/app.log
