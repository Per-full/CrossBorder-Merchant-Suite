  "version": "1.0.2",
  "description": "CrossBorder Merchant Suite Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "ts-node-dev --respawn src/worker.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": ["ecommerce", "tiktok", "xianyu", "1688"],
  "author": "Per-full",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.0.3",
    "sequelize": "^6.32.0",
    "pg": "^8.10.0",
    "redis": "^4.6.7",
    "ioredis": "^5.3.2",
    "bullmq": "^1.86.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "puppeteer": "^20.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "prettier": "^2.8.8",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@typescript-eslint/parser": "^5.59.5"
  }
